# Database Configuration
DATABASE_URL=mysql://user:password@host:port/database

# Email Configuration (Gmail)
GMAIL_USER=vibeonsupport@gmail.com
GMAIL_APP_PASSWORD=your_app_password_here

# OAuth Configuration (Manus)
EXPO_PUBLIC_OAUTH_PORTAL_URL=https://oauth.manus.im
EXPO_PUBLIC_OAUTH_SERVER_URL=https://api.manus.im
EXPO_PUBLIC_APP_ID=your_app_id
EXPO_PUBLIC_OWNER_OPEN_ID=your_owner_open_id
EXPO_PUBLIC_OWNER_NAME=your_owner_name
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000

# Node Environment
NODE_ENV=production
